---
import Layout from "../../layouts/Layout.astro";
import BlogHeader from "../../components/BlogHeader.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";
import { slide } from "astro:transitions";
import { BLOG_SITE_DESCRIPTION, BLOG_SITE_TITLE } from "../../config";
import AstroLink from "../../components/AstroLink.astro";

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const blogEntries = await getCollection("posts", ({ data }) => {
    return data.draft !== true;
  });
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}
// 2. When it's time to render, you can get the entry directly from the prop
const { entry } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage = "" } = entry.data;
const { Content } = await entry.render();
---

<Layout title={title} description={description}>
  <BlogHeader title={BLOG_SITE_TITLE} description={BLOG_SITE_DESCRIPTION} />
  <main transition:animate={slide({ duration: '0.5s' })}>
    <article class="mx-auto my-[30px] max-w-[800px] px-5 sp:px-4">
      <div class="mb-10 text-center">
        {heroImage && <img width={720} height={360} src={heroImage} alt="" class="mx-auto mb-[30px] rounded-lg shadow-card" />}
        <h1 class="text-[2.25rem] m-0 mb-5 leading-[1.3] font-bold sp:text-[1.75rem]" transition:name={"blog-title-" + entry.slug}>{title}</h1>
        <div class="flex justify-center items-center flex-wrap gap-5 text-text-light text-[0.9rem]">
          {
            pubDate && (
              <span class="flex items-center" transition:name={"blog-pub-date-" + entry.slug}>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="align-middle mr-[5px]"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                <time class="mx-[5px]">
                  {new Date(pubDate).toLocaleDateString("ja-jp", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
                作成
              </span>
            )
          }
          {
            updatedDate && (
              <span class="flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="align-middle mr-[5px]"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                <time class="mx-[5px]">
                  {new Date(updatedDate).toLocaleDateString("ja-jp", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
                更新
              </span>
            )
          }
        </div>
      </div>
      <div class="mb-10 prose prose-lg max-w-none prose-headings:text-text prose-p:text-text prose-a:text-primary prose-a:transition-colors prose-a:duration-300 hover:prose-a:text-primary-light prose-strong:text-text prose-code:text-text prose-code:bg-background-alt prose-code:px-[5px] prose-code:py-[2px] prose-code:rounded prose-pre:bg-background-alt prose-blockquote:border-primary-light prose-blockquote:bg-background-alt prose-blockquote:text-text-light prose-th:bg-background-alt prose-tr:even:bg-background-alt prose-img:rounded prose-img:mx-auto">
        <Content />
      </div>
      <div class="mt-[50px] pt-5 border-t border-border">
        <AstroLink href="/" class="inline-flex items-center gap-2 px-4 py-2 bg-background-alt rounded transition-all duration-300 hover:bg-primary hover:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          一覧に戻る
        </AstroLink>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

